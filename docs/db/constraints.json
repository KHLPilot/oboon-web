    "constraint_type": "c",
    "definition": "CHECK (((open_end IS NULL) OR (((open_end ~ '^\\\\d{4}-(0[1-9]|1[0-2])$'::text) AND (to_char((to_date((open_end || '-01'::text), 'YYYY-MM-DD'::text))::timestamp with time zone, 'YYYY-MM'::text) = open_end)) OR ((open_end ~ '^\\\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\\\d|3[01])$'::text) AND (to_char((to_date(open_end, 'YYYY-MM-DD'::text))::timestamp with time zone, 'YYYY-MM-DD'::text) = open_end)))))"
